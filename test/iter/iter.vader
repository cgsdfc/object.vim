Before;
let X = object#class('X')
let IsIterable = function('object#iter#IsIterable')
let IsIterator = function('object#iter#IsIterator')

" TEST: Check Iterable {{{1
" Iterable is an object that defines a __iter__() method.
" Built-in list and str are considered Iterable.
Execute(Check Iterable);
Assert !IsIterable(1)
Assert !IsIterable(1.1)
Assert !IsIterable({})
Assert !IsIterable(v:false)
Assert !IsIterable(function('empty'))

let var = object#new(X)
Assert !IsIterable(var)

let var.__iter__ = 1
Assert !IsIterable(var)

unlet var.__iter__
function! var.__iter__()
  return {}
endfunction
Assert IsIterable(var)

Assert IsIterable('')
Assert IsIterable([])
" }}}1


" TEST: Check Iterator {{{1
" Iterator is an object that defines a __next__() method.
Execute(Check Iterator);
Assert !IsIterator(1)
Assert !IsIterator(1.1)
Assert !IsIterator({})
Assert !IsIterator(v:false)
Assert !IsIterator(function('empty'))
Assert !IsIterator(object#new(X))

function! X.__next__()
  return 1
endfunction
Assert IsIterator(object#new(X))
" }}}1


Execute(Check args);
AssertThrows call object#iter()
Log g:vader_exception
Assert g:vader_exception =~# 'TypeError'

AssertThrows call object#iter(1,1,1)
Log g:vader_exception
Assert g:vader_exception =~# 'TypeError'

AssertThrows call object#iter('', 1)
Log g:vader_exception
Assert g:vader_exception =~# 'TypeError'

AssertThrows call object#iter(1)
Log g:vader_exception
Assert g:vader_exception =~# 'TypeError'


Execute(Callable Iterator);
" This Iterator is bundled with iter.vim to implement
" the form iter(callable, sentinel).
let s:counter = 0
function! Counter()
  let s:counter += 1
  return s:counter
endfunction

let iter = object#iter(function('Counter'), 4)
Assert iter is object#iter(iter)

AssertEqual object#next(iter), 1
AssertEqual object#next(iter), 2
AssertEqual object#next(iter), 3

AssertThrows call object#next(g:iter)
Assert g:vader_exception =~# 'StopIteration'


Execute(Signature mismatch of callable);
function! TakesOneArg(x)
  return 0
endfunction
let iter = object#iter(function('TakesOneArg'), 0)
AssertThrows call object#next(g:iter)
Log g:vader_exception

" vim:ft=vim
" vim: set sw=2 sts=2 et fdm=marker:
