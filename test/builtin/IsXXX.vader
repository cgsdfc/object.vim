Before;
let Testers = [
      \ 'IsNumber',
      \ 'IsBool',
      \ 'IsObj',
      \ 'IsFloat',
      \ 'IsList',
      \ 'IsDict',
      \ 'IsString',
      \ 'IsFuncref',
      \ 'IsNumeric',
      \ 'IsSequence',
      \ ]

for func in Testers
  let {func} = function(printf('object#builtin#%s', func))
endfor

Execute(IsNumber);
Assert IsNumber(1)
Assert !IsNumber('')

Execute(IsBool);
Assert IsBool(1)
Assert IsBool(v:false)
Assert !IsBool(3)

Execute(IsDict);
Assert IsDict({})
Assert !IsDict('')

Execute(IsList);
Assert IsList([])
Assert !IsList('')

Execute(IsFloat);
Assert IsFloat(1.0)
Assert !IsFloat(1)

Execute(IsObj);
let obj = object#object()
Assert IsObj(obj)
Assert !IsObj({})

Execute(IsString);
Assert IsString('')
Assert !IsString(1)

Execute(IsFuncref);
Assert IsFuncref(function('tr'))
Assert !IsFuncref('tr')

Execute(IsNumeric);
Assert IsNumeric(1)
Assert IsNumeric(1.0)
Assert !IsNumeric('1')

Execute(IsSequence);
Assert IsSequence('')
Assert IsSequence([])
Assert !IsSequence(1)

" vim: ft=vim
" vim: set sw=2 sts=2 et fdm=marker:
