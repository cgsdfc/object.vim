" vim: ft=vim

Before;

let Testers = [
      \ 'IsNumber',
      \ 'IsBool',
      \ 'IsObj',
      \ 'IsFloat',
      \ 'IsList',
      \ 'IsDict',
      \ 'IsString',
      \ 'IsFuncref',
      \ 'IsNumeric',
      \ ]

for func in Testers
  let {func} = function(printf('object#builtin#%s', func))
endfor

Execute(Number);
Assert IsNumber(1)
Assert !IsNumber('')

Execute(Bool);
Assert IsBool(1)
Assert IsBool(v:false)
Assert !IsBool(3)

Execute(Dict);
Assert IsDict({})
Assert !IsDict('')

Execute(List);
Assert IsList([])
Assert !IsList('')

Execute(Float);
Assert IsFloat(1.0)
Assert !IsFloat(1)

Execute(Obj);
let obj = object#object()
Assert IsObj(obj)
Assert !IsObj({})

Execute(String);
Assert IsString('')
Assert !IsString(1)

Execute(Funcref);
Assert IsFuncref(function('tr'))
Assert !IsFuncref('tr')

Execute(Numeric);
Assert IsNumeric(1)
Assert IsNumeric(1.0)
Assert !IsNumeric('1')
