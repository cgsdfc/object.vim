" vim: ft=vim

Execute(String);
Assert object#in('this', 'this is a string')
Assert object#in('is', 'this is a string')
Assert object#in('a', 'this is a string')
Assert object#in('string', 'this is a string')
Assert !object#in('that', 'this is a string')


Execute(Corner case: empty string);
Assert object#in('', 'haystack')
Assert object#in('', '')
Assert !object#in('needle', '')


Execute(List);
let haystack = range(10)
for needle in haystack
  Assert object#in(needle, haystack)
endfor

Assert !object#in(-1, haystack)
Assert !object#in(10, haystack)


Execute(Dict);
let haystack = {
      \ 'Germany': 'Berlin',
      \ 'United State': 'Hashington DC',
      \ 'England': 'London',
      \ 'France': 'Paris',
      \ 'Russia': 'Moscow',
      \}

for x in keys(haystack)
  Assert object#in(x, haystack)
endfor

Assert !object#in('NoWhere', haystack)


Execute(User-defined __contains__);
let X = object#class('X')
function! X.__contains__(Key)
  return 1
endfunction

let x = object#new(X)
for i in range(10)
  Assert object#in(i, x)
endfor


Execute(Throw TypeError when arg is not iterable);
let input = [ function('tr'), 1 ]
for X in input
  AssertThrows call object#in(1, g:X)
  Assert g:vader_exception =~# 'TypeError'
endfor
